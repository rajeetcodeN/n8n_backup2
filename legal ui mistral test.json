      },
      "type": "@n8n/n8n-nodes-langchain.lmChatMistralCloud",
      "typeVersion": 1,
      "position": [
        1200,
        96
      ],
      "id": "0fc187d6-edfd-4342-a171-e52899baec17",
      "name": "Mistral Cloud Chat Model",
