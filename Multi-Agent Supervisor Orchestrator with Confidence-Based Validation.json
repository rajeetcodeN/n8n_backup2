      "id": "a5aad0cb-bfe1-4433-bac2-f6b9ab074c65",
      "name": "Prepare Retry Request",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        304,
        -128
      ]
    },
    {
      "parameters": {
        "jsCode": "const retryCount = $input.first().json.retryCount || 0;\nconst maxRetries = $('Workflow Configuration').first().json.maxRetries;\nconst newRetryCount = retryCount + 1;\n\nif (newRetryCount > maxRetries) {\n  return [{\n    json: {\n      ...$input.first().json,\n      status: 'failed',\n      message: `Maximum retries (${maxRetries}) exceeded. Confidence threshold not met.`,\n      retryCount: newRetryCount\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    retryCount: newRetryCount,\n    chatInput: $input.first().json.chatInput + '\\n\\n' + $input.first().json.refinementPrompt\n  }\n}];"
      },
      "id": "234aa083-4a49-42f9-99d4-08d85e802e35",
      "name": "Increment Retry Counter",
