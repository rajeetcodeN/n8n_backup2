          "name": "Postgres account dbt rn"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "id-1",
              "leftValue": "={{ $('Query Inactive Users').item.json.lifetime_value }}",
              "rightValue": "={{ $('Workflow Configuration').first().json.highValueThreshold }}",
              "operator": {
                "type": "number",
                "operation": "gt"
              }
