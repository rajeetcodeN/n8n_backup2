    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT user_id, email, name, last_active, lifetime_value FROM users WHERE last_active < NOW() - INTERVAL '={{ $('Workflow Configuration').first().json.inactivityThresholdDays }} days' AND status = 'active'",
        "options": {}
      },
      "id": "b626c7cc-21db-4c58-8252-90d127672637",
      "name": "Query Inactive Users",
