    {
      "parameters": {
        "jsCode": "// Validate provider response structure\nconst items = $input.all();\nconst validatedItems = [];\n\nfor (const item of items) {\n  let validationPassed = true;\n  let validationErrors = [];\n  \n  try {\n    // Check if item has json data\n    if (!item.json) {\n      validationErrors.push('Missing json data');\n      validationPassed = false;\n    }\n    \n    // Check for required fields in the response\n    const requiredFields = ['model', 'choices'];\n    for (const field of requiredFields) {\n      if (!item.json.hasOwnProperty(field)) {\n        validationErrors.push(`Missing required field: ${field}`);\n        validationPassed = false;\n      }\n    }\n    \n    // Validate choices array exists and has content\n    if (item.json.choices && Array.isArray(item.json.choices)) {\n      if (item.json.choices.length === 0) {\n        validationErrors.push('Choices array is empty');\n        validationPassed = false;\n      } else {\n        // Check first choice has message content\n        const firstChoice = item.json.choices[0];\n        if (!firstChoice.message || !firstChoice.message.content) {\n          validationErrors.push('Missing message content in choices');\n          validationPassed = false;\n        }\n      }\n    } else if (item.json.choices) {\n      validationErrors.push('Choices is not an array');\n      validationPassed = false;\n    }\n    \n    // Ensure response is valid JSON (already parsed, but verify structure)\n    try {\n      JSON.stringify(item.json);\n    } catch (e) {\n      validationErrors.push('Response cannot be serialized to JSON');\n      validationPassed = false;\n    }\n    \n    // Add validation result to item\n    validatedItems.push({\n      json: {\n        ...item.json,\n        validation_passed: validationPassed,\n        validation_errors: validationErrors.length > 0 ? validationErrors : undefined\n      }\n    });\n    \n  } catch (error) {\n    // Handle any unexpected errors\n    validatedItems.push({\n      json: {\n        ...item.json,\n        validation_passed: false,\n        validation_errors: [`Validation error: ${error.message}`]\n      }\n    });\n  }\n}\n\nreturn validatedItems;"
      },
      "id": "8a5b360e-c677-493e-bdf4-1056e13a845f",
      "name": "Output Validator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1328,
        592
      ]
