    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Extract data from previous nodes\nconst providerResponse = $input.item.json;\nconst modelUsed = providerResponse.model || 'unknown';\nconst inputTokens = providerResponse.usage?.prompt_tokens || providerResponse.usage?.input_tokens || 0;\nconst outputTokens = providerResponse.usage?.completion_tokens || providerResponse.usage?.output_tokens || 0;\n\n// Pricing per 1M tokens (USD)\nconst pricing = {\n  'openai': {\n    'gpt-4': { input: 30, output: 60 },\n    'gpt-4-turbo': { input: 10, output: 30 },\n    'gpt-3.5-turbo': { input: 0.5, output: 1.5 },\n    'gpt-4o': { input: 5, output: 15 },\n    'gpt-4o-mini': { input: 0.15, output: 0.6 }\n  },\n  'anthropic': {\n    'claude-3-opus': { input: 15, output: 75 },\n    'claude-3-sonnet': { input: 3, output: 15 },\n    'claude-3-haiku': { input: 0.25, output: 1.25 },\n    'claude-3-5-sonnet': { input: 3, output: 15 }\n  },\n  'azure': {\n    'gpt-4': { input: 30, output: 60 },\n    'gpt-4-turbo': { input: 10, output: 30 },\n    'gpt-35-turbo': { input: 0.5, output: 1.5 }\n  }\n};\n\n// Determine provider from model name or previous node data\nlet provider = 'openai'; // default\nif (providerResponse.provider) {\n  provider = providerResponse.provider.toLowerCase();\n} else if (modelUsed.includes('claude')) {\n  provider = 'anthropic';\n} else if (modelUsed.includes('gpt')) {\n  provider = 'openai';\n}\n\n// Find matching pricing\nlet modelPricing = { input: 0, output: 0 };\nif (pricing[provider]) {\n  // Try exact match first\n  if (pricing[provider][modelUsed]) {\n    modelPricing = pricing[provider][modelUsed];\n  } else {\n    // Try partial match\n    for (const [key, value] of Object.entries(pricing[provider])) {\n      if (modelUsed.includes(key)) {\n        modelPricing = value;\n        break;\n      }\n    }\n  }\n}\n\n// Calculate cost (pricing is per 1M tokens)\nconst inputCost = (inputTokens / 1000000) * modelPricing.input;\nconst outputCost = (outputTokens / 1000000) * modelPricing.output;\nconst totalCostUsd = inputCost + outputCost;\n\n// Return all original data plus cost calculations\nreturn {\n  ...providerResponse,\n  input_tokens: inputTokens,\n  output_tokens: outputTokens,\n  total_cost_usd: parseFloat(totalCostUsd.toFixed(6)),\n  model_used: modelUsed,\n  cost_breakdown: {\n    input_cost_usd: parseFloat(inputCost.toFixed(6)),\n    output_cost_usd: parseFloat(outputCost.toFixed(6)),\n    provider: provider\n  }\n};"
      },
