    {
      "parameters": {
        "jsCode": "// Token Budget Check\n// Validates if estimated tokens from policy engine are within budget\n\nconst items = $input.all();\nconst outputItems = [];\n\nfor (const item of items) {\n  const estimatedTokens = item.json.estimated_tokens || 0;\n  const maxTokenBudget = item.json.maxTokenBudget || Infinity;\n  \n  if (estimatedTokens > maxTokenBudget) {\n    // Budget exceeded - return error object\n    outputItems.push({\n      json: {\n        ...item.json,\n        budgetExceeded: true,\n        budgetApproved: false,\n        error: `Token budget exceeded: ${estimatedTokens} tokens requested, but limit is ${maxTokenBudget}`,\n        estimatedTokens,\n        maxTokenBudget\n      }\n    });\n  } else {\n    // Budget approved - pass through\n    outputItems.push({\n      json: {\n        ...item.json,\n        budgetExceeded: false,\n        budgetApproved: true,\n        estimatedTokens,\n        maxTokenBudget\n      }\n    });\n  }\n}\n\nreturn outputItems;"
      },
