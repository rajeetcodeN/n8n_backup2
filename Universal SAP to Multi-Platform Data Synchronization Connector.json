    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst mapped = items.flatMap(item => {\n  const records = item.json.records || [];\n  return records.map(record => ({\n    json: {\n      sapKey: record.MANDT + '-' + record.KUNNR,\n      properties: {\n        firstname: record.NAME1?.split(' ')[0],\n        lastname: record.NAME1?.split(' ').slice(1).join(' '),\n        email: record.SMTP_ADDR,\n        phone: record.TEL_NUMBER,\n        address: record.STRAS,\n        city: record.ORT01,\n        zip: record.PSTLZ,\n        country: record.LAND1,\n        customer_number: record.KUNNR\n      },\n      _originalSapData: record\n    }\n  }));\n});\nreturn mapped;"
      },
