    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst mapped = items.flatMap(item => {\n  const records = item.json.records || [];\n  return records.map(record => ({\n    json: {\n      sapKey: record.MANDT + '-' + record.KUNNR,\n      Name: record.NAME1,\n      Email: record.SMTP_ADDR,\n      Phone: record.TEL_NUMBER,\n      BillingStreet: record.STRAS,\n      BillingCity: record.ORT01,\n      BillingPostalCode: record.PSTLZ,\n      BillingCountry: record.LAND1,\n      AccountNumber: record.KUNNR,\n      _originalSapData: record\n    }\n  }));\n});\n\nreturn mapped;"
      },
