    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst mapped = items.flatMap(item => {\n  const records = item.json.records || [];\n  return records.map(record => ({\n    json: {\n      sapKey: record.MANDT + '-' + record.MATNR,\n      title: record.MAKTX,\n      product_type: record.MTART,\n      vendor: record.MFRNR,\n      sku: record.MATNR,\n      price: record.NETPR,\n      inventory_quantity: record.LABST,\n      weight: record.BRGEW,\n      weight_unit: record.GEWEI,\n      _originalSapData: record\n    }\n  }));\n});\nreturn mapped;"
      },
      "id": "e43a9fb3-341d-48ed-8632-851fca6403fb",
