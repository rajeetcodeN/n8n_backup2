      "id": "ffde1a2b-e1f9-41f6-a9cb-6c6cab472892",
      "name": "Merge CRM and DB Data",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        -1120,
        288
      ]
    },
    {
      "parameters": {
        "jsCode": "// Get CRM and DB data from merged inputs\nconst crmData = $input.first().json.crmContacts || [];\nconst dbData = $input.first().json.dbContacts || [];\n\n// Create maps for efficient lookup\nconst crmMap = new Map();\nconst dbMap = new Map();\n\n// Index CRM records by email and ID\ncrmData.forEach(record => {\n  const email = record.email?.toLowerCase();\n  const id = record.id || record.hs_object_id;\n  if (email) crmMap.set(`email:${email}`, record);\n  if (id) crmMap.set(`id:${id}`, record);\n});\n\n// Index DB records by email and ID\ndbData.forEach(record => {\n  const email = record.email?.toLowerCase();\n  const id = record.id || record.contact_id;\n  if (email) dbMap.set(`email:${email}`, record);\n  if (id) dbMap.set(`id:${id}`, record);\n});\n\nconst changes = [];\nconst processedEmails = new Set();\nconst processedIds = new Set();\n\n// Helper function to get timestamp\nfunction getTimestamp(record, source) {\n  if (source === 'crm') {\n    return new Date(record.lastmodifieddate || record.createdate || 0);\n  } else {\n    return new Date(record.updated_at || record.created_at || 0);\n  }\n}\n\n// Process CRM records\ncrmData.forEach(crmRecord => {\n  const email = crmRecord.email?.toLowerCase();\n  const id = crmRecord.id || crmRecord.hs_object_id;\n  \n  let dbRecord = null;\n  \n  // Try to find matching DB record by ID first, then email\n  if (id && dbMap.has(`id:${id}`)) {\n    dbRecord = dbMap.get(`id:${id}`);\n  } else if (email && dbMap.has(`email:${email}`)) {\n    dbRecord = dbMap.get(`email:${email}`);\n  }\n  \n  if (dbRecord) {\n    // Record exists in both - check for updates\n    const crmTimestamp = getTimestamp(crmRecord, 'crm');\n    const dbTimestamp = getTimestamp(dbRecord, 'db');\n    \n    // Check if data is different (simple comparison)\n    const isDifferent = JSON.stringify(crmRecord) !== JSON.stringify(dbRecord);\n    \n    if (isDifferent) {\n      if (crmTimestamp > dbTimestamp) {\n        changes.push({\n          changeType: 'update_db',\n          source: 'crm',\n          record: crmRecord,\n          crmTimestamp: crmTimestamp.toISOString(),\n          dbTimestamp: dbTimestamp.toISOString()\n        });\n      } else if (dbTimestamp > crmTimestamp) {\n        changes.push({\n          changeType: 'update_crm',\n          source: 'db',\n          record: dbRecord,\n          crmTimestamp: crmTimestamp.toISOString(),\n          dbTimestamp: dbTimestamp.toISOString()\n        });\n      } else {\n        // Same timestamp but different data - mark as duplicate/conflict\n        changes.push({\n          changeType: 'duplicate',\n          source: 'both',\n          crmRecord: crmRecord,\n          dbRecord: dbRecord,\n          crmTimestamp: crmTimestamp.toISOString(),\n          dbTimestamp: dbTimestamp.toISOString()\n        });\n      }\n    }\n    \n    if (email) processedEmails.add(email);\n    if (id) processedIds.add(id);\n  } else {\n    // Record only exists in CRM - new in CRM\n    changes.push({\n      changeType: 'new_in_crm',\n      source: 'crm',\n      record: crmRecord\n    });\n    \n    if (email) processedEmails.add(email);\n    if (id) processedIds.add(id);\n  }\n});\n\n// Process DB records to find ones not in CRM\ndbData.forEach(dbRecord => {\n  const email = dbRecord.email?.toLowerCase();\n  const id = dbRecord.id || dbRecord.contact_id;\n  \n  // Skip if already processed\n  if ((email && processedEmails.has(email)) || (id && processedIds.has(id))) {\n    return;\n  }\n  \n  // Record only exists in DB - new in DB\n  changes.push({\n    changeType: 'new_in_db',\n    source: 'db',\n    record: dbRecord\n  });\n});\n\nreturn changes.map(change => ({ json: change }));"
      },
