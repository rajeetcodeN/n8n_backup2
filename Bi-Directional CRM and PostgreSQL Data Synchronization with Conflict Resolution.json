    {
      "parameters": {
        "jsCode": "// Loop through all items and output each change separately\nconst outputItems = [];\n\nfor (const item of $input.all()) {\n  if (item.json.changes && Array.isArray(item.json.changes)) {\n    // If changes is an array, output each change as a separate item\n    for (const change of item.json.changes) {\n      outputItems.push({\n        json: change\n      });\n    }\n  } else {\n    // If no changes array, output the item as is\n    outputItems.push({\n      json: item.json\n    });\n  }\n}\n\nreturn outputItems;"
      },
