          "systemMessage": "You are an AI model being tested for drift detection. Answer the question provided accurately and completely."
        }
      },
      "id": "b70c0926-0185-4166-ac9f-621e35ea2302",
      "name": "Execute Current LLM",
      "type": "@n8n/n8n-nodes-langchain.agent",
