    },
    {
      "parameters": {
        "fromEmail": "<__PLACEHOLDER_VALUE__Sender email address__>",
        "toEmail": "<__PLACEHOLDER_VALUE__Alert recipient email address__>",
        "subject": "AI Model Drift Alert - Performance Regression Detected",
        "html": "=<h2>AI Model Drift Alert</h2>\n<p><strong>Drift detected at:</strong> {{ $json.timestamp }}</p>\n<p><strong>Drift Percentage:</strong> {{ $json.driftPercentage.toFixed(2) }}%</p>\n\n<h3>Scores:</h3>\n<ul>\n  <li>Accuracy: {{ $json.accuracy }}/10</li>\n  <li>Logic: {{ $json.logic }}/10</li>\n  <li>Completeness: {{ $json.completeness }}/10</li>\n  <li>Average: {{ $json.avgScore.toFixed(2) }}/10</li>\n</ul>\n\n<h3>Test Details:</h3>\n<p><strong>Question:</strong> {{ $json.testQuestion }}</p>\n<p><strong>Baseline Answer:</strong> {{ $json.baselineAnswer }}</p>\n<p><strong>Current Answer:</strong> {{ $json.currentAnswer }}</p>\n\n<h3>Analysis:</h3>\n<p>{{ $json.explanation }}</p>",
        "options": {}
      },
      "id": "aafb182d-d98f-4f4b-9888-2e2bc509ecbf",
      "name": "Send Drift Alert",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        -16,
        0
      ],
      "webhookId": "7ee2b8e7-fc0c-4bd8-9ff6-94ccde782666"
    },
