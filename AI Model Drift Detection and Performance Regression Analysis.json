        80
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Baseline Answer: {{ $('Get Baseline Answers').item.json.baseline_answer }}\n\nCurrent Model Answer: {{ $('Execute Current LLM').item.json.output }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a model evaluator.\n\nCompare:\n- Baseline answer\n- Current model answer\n\nScore across:\n1. Factual accuracy (0–10)\n2. Logical consistency (0–10)\n3. Completeness (0–10)\n\nExplain discrepancies.\n\nReturn JSON:\n{\n  \"accuracy\": <score>,\n  \"logic\": <score>,\n  \"completeness\": <score>,\n  \"drift_detected\": true/false,\n  \"explanation\": \"<explanation>\"\n}"
        }
      },
      "id": "e3f0ac73-025f-4f5a-a8f1-8d6dfeb1c760",
      "name": "Score and Compare Answers",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        -816,
        80
      ]
    },
    {
      "parameters": {
        "jsCode": "// Calculate drift metrics from AI scoring output\nconst config = $('Workflow Configuration').first().json;\nconst baseline = $('Get Baseline Answers').first().json;\nconst currentAnswer = $('Execute Current LLM').first().json.output;\nconst scores = $json;\n\n// Calculate average score\nconst avgScore = (scores.accuracy + scores.logic + scores.completeness) / 3;\n\n// Calculate drift percentage (how far from perfect 10)\nconst maxPossibleScore = 30; // 3 metrics × 10 points each\nconst actualScore = scores.accuracy + scores.logic + scores.completeness;\nconst driftPercentage = ((maxPossibleScore - actualScore) / maxPossibleScore) * 100;\n\n// Determine if drift is significant based on thresholds\nconst driftDetected = scores.drift_detected || \n  driftPercentage > config.driftThreshold ||\n  (10 - scores.accuracy) > config.maxAccuracyDrop ||\n  (10 - scores.logic) > config.maxLogicDrop ||\n  (10 - scores.completeness) > config.maxCompletenessDrop;\n\nreturn {\n  json: {\n    timestamp: new Date().toISOString(),\n    testQuestion: $('Load Test Dataset').first().json.testQuestion,\n    baselineAnswer: baseline.baseline_answer,\n    currentAnswer: currentAnswer,\n    accuracy: scores.accuracy,\n    logic: scores.logic,\n    completeness: scores.completeness,\n    avgScore: avgScore,\n    driftPercentage: driftPercentage,\n    driftDetected: driftDetected,\n    explanation: scores.explanation\n  }\n};"
      },
      "id": "2c858ee3-0212-406b-a9a3-4f59af6ee9a3",
      "name": "Calculate Drift Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -464,
        80
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "id-1",
              "leftValue": "={{ $json.driftDetected }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "4467f1a3-c3cf-47e4-b6ea-0f5d13d83128",
      "name": "Drift Detected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
