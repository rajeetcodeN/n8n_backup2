      "id": "0a76c396-e471-4829-85e8-f94c45edc8a1",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.3,
      "position": [
        1352,
        320
      ],
      "credentials": {
        "openAiApi": {
          "id": "zHMgvi1Nu77MFY12",
          "name": "n8n free OpenAI API credits"
        }
      }
    },
    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"product\": {\"type\": \"string\"},\n    \"fabric\": {\"type\": \"string\"},\n    \"sizes\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n    \"quantity\": {\"type\": \"number\"},\n    \"printing\": {\"type\": \"string\"},\n    \"deadline\": {\"type\": \"string\"},\n    \"clientName\": {\"type\": \"string\"},\n    \"clientEmail\": {\"type\": \"string\"}\n  },\n  \"required\": [\"product\", \"fabric\", \"sizes\", \"quantity\", \"printing\"]\n}"
      },
      "id": "5508ea17-0e2e-4dff-94ba-947e44d68935",
      "name": "Structured Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1480,
        320
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT product_type, fabric_type, base_price, size_multiplier, print_cost, moq FROM products WHERE product_type = $1 AND fabric_type = $2",
        "options": {
          "queryReplacement": "={{ $json.product }},={{ $json.fabric }}"
        }
      },
      "id": "aece2db0-89e4-4c84-827c-a32a8dead4c5",
      "name": "Fetch Product Pricing",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1696,
        96
      ],
      "credentials": {
        "postgres": {
          "id": "yGwZ0IHTkODL3IL8",
          "name": "Postgres account dbt rn"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rfqData = $input.first().json;\nconst pricingData = $input.first().json;\nconst config = $('Workflow Configuration').first().json;\n\n// Extract pricing from database\nconst basePrice = pricingData.base_price || 0;\nconst sizeMultiplier = JSON.parse(pricingData.size_multiplier || '{}');\nconst printCost = pricingData.print_cost || 0;\nconst moq = pricingData.moq || 0;\n\n// Calculate size-adjusted base price\nlet totalBasePrice = 0;\nconst sizes = rfqData.sizes || [];\nconst quantityPerSize = Math.ceil(rfqData.quantity / sizes.length);\n\nsizes.forEach(size => {\n  const multiplier = sizeMultiplier[size] || 1;\n  totalBasePrice += basePrice * multiplier * quantityPerSize;\n});\n\n// Calculate printing cost\nconst totalPrintCost = rfqData.printing === 'yes' ? printCost * rfqData.quantity : 0;\n\n// Calculate bulk discount\nconst bulkDiscount = rfqData.quantity >= config.bulkDiscountThreshold \n  ? (totalBasePrice + totalPrintCost) * (config.bulkDiscountPercent / 100)\n  : 0;\n\n// Calculate urgency surcharge\nconst deadlineDays = rfqData.deadline ? parseInt(rfqData.deadline) : config.standardLeadTimeDays;\nconst urgencySurcharge = deadlineDays < config.standardLeadTimeDays\n  ? (totalBasePrice + totalPrintCost) * (config.urgencySurchargePercent / 100)\n  : 0;\n\n// Calculate totals\nconst subtotal = totalBasePrice + totalPrintCost;\nconst totalPrice = subtotal - bulkDiscount + urgencySurcharge;\nconst pricePerUnit = totalPrice / rfqData.quantity;\n\nreturn {\n  ...rfqData,\n  pricing: {\n    basePrice: totalBasePrice.toFixed(2),\n    printingCost: totalPrintCost.toFixed(2),\n    bulkDiscount: bulkDiscount.toFixed(2),\n    urgencySurcharge: urgencySurcharge.toFixed(2),\n    subtotal: subtotal.toFixed(2),\n    totalPrice: totalPrice.toFixed(2),\n    pricePerUnit: pricePerUnit.toFixed(2)\n  },\n  leadTime: deadlineDays < config.standardLeadTimeDays ? `${deadlineDays} days (expedited)` : `${config.standardLeadTimeDays} days (standard)`,\n  moqMet: rfqData.quantity >= moq\n};"
      },
      "id": "fe203647-327a-41e3-804f-c5bd17c8cf19",
      "name": "Calculate Quote Pricing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
