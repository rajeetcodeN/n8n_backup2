        "jsonBody": "={\n  \"document\": {\n    \"document_template_id\": \"<__PLACEHOLDER_VALUE__PDF template ID__>\",\n    \"payload\": {\n      \"clientName\": \"={{ $json.clientName }}\",\n      \"product\": \"={{ $json.product }}\",\n      \"fabric\": \"={{ $json.fabric }}\",\n      \"sizes\": \"={{ $json.sizes.join(', ') }}\",\n      \"quantity\": \"={{ $json.quantity }}\",\n      \"printing\": \"={{ $json.printing }}\",\n      \"pricePerUnit\": \"={{ $json.pricing.pricePerUnit }}\",\n      \"totalPrice\": \"={{ $json.pricing.totalPrice }}\",\n      \"basePrice\": \"={{ $json.pricing.basePrice }}\",\n      \"printingCost\": \"={{ $json.pricing.printingCost }}\",\n      \"bulkDiscount\": \"={{ $json.pricing.bulkDiscount }}\",\n      \"urgencySurcharge\": \"={{ $json.pricing.urgencySurcharge }}\",\n      \"leadTime\": \"={{ $json.leadTime }}\"\n    }\n  }\n}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
