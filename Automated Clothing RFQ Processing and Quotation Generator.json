    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.rfqText }}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an RFQ parsing assistant for a clothing supplier. Extract the following details from the customer request:\n\n- product: type of clothing (e.g., t-shirt, hoodie, polo)\n- fabric: fabric type (e.g., cotton, polyester, blend)\n- sizes: array of sizes requested (e.g., [\"S\", \"M\", \"L\", \"XL\"])\n- quantity: total number of units\n- printing: whether custom printing is required (yes/no)\n- deadline: delivery deadline or lead time requested\n- clientName: customer or company name if mentioned\n- clientEmail: customer email if mentioned\n\nReturn the data in the exact JSON schema format specified by the output parser."
        }
      },
      "id": "ce100906-ed70-4471-a2f2-60934e0f8bc6",
      "name": "Parse RFQ Details",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        1344,
        96
      ]
    },
    {
