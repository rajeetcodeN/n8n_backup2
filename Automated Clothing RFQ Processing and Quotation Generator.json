    {
      "parameters": {
        "sendTo": "={{ $json.clientEmail }}",
        "subject": "=Your Clothing Quote - {{ $json.product }} ({{ $json.quantity }} units)",
        "message": "=<html>\n<body>\n<h2>Thank you for your RFQ!</h2>\n<p>Dear {{ $json.clientName }},</p>\n<p>We are pleased to provide you with a quotation for your clothing order:</p>\n<h3>Order Details:</h3>\n<ul>\n<li><strong>Product:</strong> {{ $json.product }}</li>\n<li><strong>Fabric:</strong> {{ $json.fabric }}</li>\n<li><strong>Sizes:</strong> {{ $json.sizes.join(', ') }}</li>\n<li><strong>Quantity:</strong> {{ $json.quantity }} units</li>\n<li><strong>Custom Printing:</strong> {{ $json.printing }}</li>\n</ul>\n<h3>Pricing Breakdown:</h3>\n<ul>\n<li><strong>Base Price:</strong> ${{ $json.pricing.basePrice }}</li>\n<li><strong>Printing Cost:</strong> ${{ $json.pricing.printingCost }}</li>\n<li><strong>Bulk Discount:</strong> -${{ $json.pricing.bulkDiscount }}</li>\n<li><strong>Urgency Surcharge:</strong> +${{ $json.pricing.urgencySurcharge }}</li>\n<li><strong>Total Price:</strong> ${{ $json.pricing.totalPrice }}</li>\n<li><strong>Price per Unit:</strong> ${{ $json.pricing.pricePerUnit }}</li>\n</ul>\n<p><strong>Lead Time:</strong> {{ $json.leadTime }}</p>\n<p>Please find the detailed quotation attached as PDF.</p>\n<p>Best regards,<br>Your Clothing Supplier Team</p>\n</body>\n</html>",
        "options": {
